   "source": [
    "capital = int(input(\"元金を入力してください:\"))\n",
    "interest = int(input(\"年利を入力してください:\")) / 100\n",
    "acc = capital\n",
    "for _ in range(10):\n",
    "    acc = acc * (1 + interest)\n",
    "\n",
    "print(f\"10年後の金額:{acc:.2f}\")\n"
