   "source": [
    "import statistics\n",
    "\n",
    "grades = [85, 90, 78, 92, 88] \n",
    "mean = statistics.mean(grades)\n",
    "max = max(grades)\n",
    "min = min(grades)\n",
    "ge_mean_number = len([x for x in grades if x >= mean])\n",
    "print(f\"平均点: {mean}\")\n",
    "print(f\"最高点: {max}\")\n",
    "print(f\"最低点: {min}\")\n",
    "print(f\"平均以上の学生数: {ge_mean_number}\")\n"
   ]
  }
 ],
